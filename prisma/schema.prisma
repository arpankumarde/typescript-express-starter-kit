generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String   @db.VarChar(50)
  phone     String   @db.VarChar(13)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
